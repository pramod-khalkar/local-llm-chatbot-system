# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
ENVIRONMENT=development

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://chatbot_user:chatbot_password@postgres:5432/chatbot_db
DATABASE_ECHO=false

# ============================================
# LLM ORCHESTRATION SERVICE
# ============================================
ORCHESTRATION_HOST=0.0.0.0
ORCHESTRATION_PORT=8001
ORCHESTRATION_RELOAD=true

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_HOST=http://ollama:11434
# OLLAMA_MODEL options:
#   - tinyllama (default: lightweight, ~637MB, fast)
#   - llama2 (more powerful: ~3.8GB, better quality)
OLLAMA_MODEL=tinyllama
# OLLAMA_EMBEDDING_MODEL: Currently using nomic-embed-text (only option)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================
# CHATGPT INTEGRATION (NEW!)
# ============================================
# Enable ChatGPT for routing and RAG refinement (recommended)
USE_CHATGPT_ROUTING=true
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
# Model options: gpt-3.5-turbo (cheaper), gpt-4 (more powerful)
CHATGPT_MODEL=gpt-3.5-turbo

# ============================================
# VECTOR DATABASE (FAISS)
# ============================================
FAISS_INDEX_PATH=/data/faiss_index
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ============================================
# MCP SERVER CONFIGURATION
# ============================================
MCP_SERVER_HOST=mcp-server
MCP_SERVER_PORT=8002
MCP_TOOLS=todo-manager
TODO_API_BASE_URL=http://todoapp-api:8080
HOST=0.0.0.0
PORT=8002

# ============================================
# ORCHESTRATION SERVICE
# ============================================
ORCHESTRATION_URL=http://llm-orchestration:8001
ORCHESTRATION_HOST=0.0.0.0
ORCHESTRATION_PORT=8001
ORCHESTRATION_RELOAD=true

# ============================================
# SPEECH-TO-TEXT CONFIGURATION
# ============================================
SPEECH_PROVIDER=openai  # or local whisper
SPEECH_MODEL=whisper-1

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# LLM PROVIDER (for future swapping)
# ============================================
LLM_PROVIDER=ollama  # options: ollama, openai, gemini
TEMPERATURE=0.7
MAX_TOKENS=2048

# ============================================
# GEMINI CONFIGURATION
# ============================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
