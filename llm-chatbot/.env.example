# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
ENVIRONMENT=development

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://chatbot_user:chatbot_password@postgres:5432/chatbot_db
DATABASE_ECHO=false

# ============================================
# LLM ORCHESTRATION SERVICE
# ============================================
ORCHESTRATION_HOST=0.0.0.0
ORCHESTRATION_PORT=8001
ORCHESTRATION_RELOAD=true

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_HOST=http://ollama:11434
# OLLAMA_MODEL options:
#   - tinyllama (default: lightweight, ~637MB, fast)
#   - llama2 (more powerful: ~3.8GB, better quality)
#OLLAMA_MODEL=llama2
OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_EMBEDDING_MODEL: Currently using nomic-embed-text (only option)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================
# VECTOR DATABASE (FAISS)
# ============================================
FAISS_INDEX_PATH=/data/faiss_index
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ============================================
# MCP SERVER CONFIGURATION
# ============================================
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8002
MCP_TOOLS=todo-manager

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_ORCHESTRATION_URL=http://localhost:8001/api

# ============================================
# SPEECH-TO-TEXT CONFIGURATION
# ============================================
SPEECH_PROVIDER=openai  # or local whisper
SPEECH_MODEL=whisper-1
OPENAI_API_KEY=  # Only if using OpenAI

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# LLM PROVIDER (for future swapping)
# ============================================
LLM_PROVIDER=ollama  # ollama, openai, anthropic
TEMPERATURE=0.1
MAX_TOKENS=800
